<Window x:Class="BatteryGuardian.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Battery Guardian" Height="450" Width="350"
        Background="#121212" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    
    <Window.Resources>
        <!-- Style Tombol Sesuai PRD -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="18" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" Padding="15,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <!-- Hover Style Logic -->
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Foreground" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <StackPanel>
            <!-- Header -->
            <TextBlock Text="Battery Guardian" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
            
            <!-- Card Dashboard -->
            <Border Background="#1D1D1D" CornerRadius="18" Padding="20" Margin="0,0,0,20">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Battery Status" Foreground="#BDBDBD" FontSize="14" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding BatteryPercentage, StringFormat={}{0}%}" Foreground="White" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusText}" Foreground="#BDBDBD" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <!-- Control Actions -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Button Content="Enable" Command="{Binding EnableCommand}" Margin="5"/>
                <Button Content="Disable" Command="{Binding DisableCommand}" Margin="5"/>
            </StackPanel>

            <TextBlock Text="Status: Running in Background" Foreground="#BDBDBD" FontSize="11" HorizontalAlignment="Center" Margin="0,20,0,0"/>
        </StackPanel>
    </Grid>
</Window>