<Window x:Class="BatreConservation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BatreConservation" MinHeight="560" MinWidth="420" Height="590" Width="430"
        Background="#0F172A" WindowStartupLocation="CenterScreen" ResizeMode="CanResize">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#38BDF8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="16" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" Padding="14,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#38BDF8"/>
                    <Setter Property="Foreground" Value="#0F172A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="18">
            <StackPanel>
                <Border Background="#111827" CornerRadius="20" Padding="16" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="BatreConservation" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="ThinkPad T480 battery helper" Foreground="#93C5FD" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <Border Background="#1D4ED8" CornerRadius="999" Padding="6,3" HorizontalAlignment="Center" Margin="0,10,0,0">
                            <TextBlock Text="Lenovo focused" Foreground="White" FontSize="11"/>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Background="#1E293B" CornerRadius="18" Padding="18" Margin="0,0,0,12">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Current battery" Foreground="#CBD5E1" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding BatteryPercentage, StringFormat={}{0}%}" Foreground="White" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusText}" Foreground="#93C5FD" FontSize="13" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="#111827" CornerRadius="16" Padding="12" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Threshold settings" Foreground="White" FontWeight="Bold" Margin="0,0,0,8"/>
                        <Border Background="#1E293B" CornerRadius="12" Padding="8" Margin="0,0,0,8">
                            <TextBlock Text="{Binding ThresholdSummary}" Foreground="#93C5FD" FontSize="13" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8" HorizontalAlignment="Center">
                            <TextBlock Text="Stop at" Foreground="#CBD5E1" Width="90" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding StopCharging, UpdateSourceTrigger=PropertyChanged}" Width="78" Height="30" FontSize="14" TextAlignment="Center"/>
                            <TextBlock Text="%" Foreground="#CBD5E1" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Resume at" Foreground="#CBD5E1" Width="90" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding ResumeCharging, UpdateSourceTrigger=PropertyChanged}" Width="78" Height="30" FontSize="14" TextAlignment="Center"/>
                            <TextBlock Text="%" Foreground="#CBD5E1" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Nilai dipaksa berada di rentang 0–100% untuk menjaga kestabilan." Foreground="#94A3B8" FontSize="10" Margin="0,6,0,0" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="#111827" CornerRadius="16" Padding="12" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Conservation mode" Foreground="White" FontWeight="Bold" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                            <Button Content="Enable" Command="{Binding EnableCommand}" Margin="4"/>
                            <Button Content="Disable" Command="{Binding DisableCommand}" Margin="4"/>
                        </StackPanel>
                        <TextBlock Text="Designed for ThinkPad T480 monitoring and threshold handling." Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="ThinkPad T480 focused • honest monitoring helper" Foreground="#64748B" FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>